# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
# Get this from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── SLACK ────────────────────────────────────────────────────────────────────
# Bot Token — from api.slack.com → Your App → OAuth & Permissions
# Starts with xoxb-
SLACK_BOT_TOKEN=xoxb-...

# App Token — from api.slack.com → Your App → Basic Information → App-Level Tokens
# Must have connections:write scope. Starts with xapp-
SLACK_APP_TOKEN=xapp-...

# Bot's own User ID — find this in Slack: right-click the bot user → View profile → copy Member ID
# Used to avoid the bot responding to its own messages
SLACK_BOT_USER_ID=U...

# ─── SLACK CHANNELS ───────────────────────────────────────────────────────────
# Use channel names (with #) or channel IDs
# Channel IDs are more reliable — right-click channel in Slack → Copy link → ID is the last segment
AGENT_CHANNEL=#ng-pm-agent
STANDUP_CHANNEL=#ng-daily-standup
OPS_CHANNEL=#ng-ops-management
